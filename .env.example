# Which LLM provider the Agent Generator uses: claude | openai | gemini
LLM_PROVIDER=claude

# Model override (optional; each provider has a sensible default)
LLM_MODEL=

# Provider credentials (set the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Nexla context layer tries Nexla first, then falls back to local extraction on timeout/error.
# Put the real service key only in .env.
NEXLA_API_KEY=
NEXLA_API_BASE=https://dataops.nexla.io/nexla-api
# Compatibility alias for notes that use EXLA_API_BASE.
EXLA_API_BASE=
NEXLA_TIMEOUT_SECONDS=60
# Auth: auto (try /token service-key exchange, fall back to key-as-bearer) | bearer | token_exchange
NEXLA_AUTH_MODE=auto
# Records endpoint path template ({id} is substituted).
NEXLA_RECORDS_PATH=/data_sets/{id}/samples
# Per-source unified Nexset ids (read both, combine locally).
# Leave blank to skip Nexla and use local extraction directly.
NEXLA_PDF_RESOURCE_ID=
NEXLA_XLSX_RESOURCE_ID=

# Zero CLI boundary. The provider detects the CLI, probes safely, and falls back to fixtures.
ZERO_CLI_PATH=
ZERO_CLI_TIMEOUT_SECONDS=12
# Optional future live search command. Use {query} as the capability name placeholder.
ZERO_CLI_SEARCH_COMMAND_TEMPLATE=

# App
MISELOOP_ENV=dev
LOG_LEVEL=INFO
